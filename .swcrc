{
	"$schema": "https://json.schemastore.org/swcrc",
	"jsc": {
		"parser": {
			"syntax": "typescript",
			"decorators": true,
			"dynamicImport": false
		},
		"baseUrl": "./",
		"transform": {
			"decoratorMetadata": true
		},
		"target": "esnext"
	},
	"module": {
		"type": "es6",
		"resolveFully": true
	},
	"minify": false
}
